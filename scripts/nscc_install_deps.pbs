#!/usr/bin/env bash
#PBS -j oe

set -euo pipefail

cd "${PBS_O_WORKDIR:-$PWD}"
mkdir -p nscc_logs
LOG_FILE="nscc_logs/install_deps.${PBS_JOBID:-manual}.log"
exec > >(tee -a "${LOG_FILE}") 2>&1

echo "=== NSCC ASPS dependency install ==="
echo "started_at: $(date)"
echo "host: $(hostname)"
echo "workdir: $(pwd)"

if ! type module >/dev/null 2>&1 && [[ -f /opt/cray/pe/modules/3.2.11.6/init/bash ]]; then
  # shellcheck disable=SC1091
  source /opt/cray/pe/modules/3.2.11.6/init/bash
fi

if type module >/dev/null 2>&1; then
  module purge
  module load "${NSCC_PYTORCH_MODULE:-pytorch/2.6.0-py3-cu11.8}"
  module list
else
  echo "NSCC module command is not available." >&2
  exit 1
fi

export PYTHONUNBUFFERED=1
export PIP_CACHE_DIR="${PIP_CACHE_DIR:-${HOME}/scratch/pip-cache}"
mkdir -p "${PIP_CACHE_DIR}"

python3 -V
python3 -m pip --version
python3 -m pip install --user --upgrade pip setuptools wheel
python3 -m pip install --user --upgrade \
  accelerate \
  func_timeout \
  jsonlines \
  matplotlib \
  openai \
  pandas \
  python-dateutil \
  pyyaml \
  regex \
  safetensors \
  sentencepiece \
  sympy \
  tenacity \
  tokenizers \
  tqdm

python3 -m pip install --user --upgrade -e ASPS/custom_transformers_packages/gsm8k_strategyqa

python3 - <<'PY'
import importlib

mods = [
    "torch",
    "transformers",
    "yaml",
    "pandas",
    "tqdm",
    "jsonlines",
    "regex",
    "func_timeout",
    "sympy",
    "matplotlib",
    "openai",
    "accelerate",
    "sentencepiece",
]

for name in mods:
    mod = importlib.import_module(name)
    print(name, "OK", getattr(mod, "__version__", ""))
PY

echo "finished_at: $(date)"
echo "log_file: ${LOG_FILE}"
