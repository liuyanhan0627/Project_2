#!/usr/bin/env bash
#PBS -j oe

set -euo pipefail

cd "${PBS_O_WORKDIR:-$PWD}"
mkdir -p nscc_logs
LOG_FILE="nscc_logs/install_deps.${PBS_JOBID:-manual}.log"
exec > >(tee -a "${LOG_FILE}") 2>&1

echo "=== NSCC ASPS dependency install ==="
echo "started_at: $(date)"
echo "host: $(hostname)"
echo "workdir: $(pwd)"

if ! type module >/dev/null 2>&1 && [[ -f /opt/cray/pe/modules/3.2.11.6/init/bash ]]; then
  # shellcheck disable=SC1091
  source /opt/cray/pe/modules/3.2.11.6/init/bash
fi

if type module >/dev/null 2>&1; then
  module purge
  module load "${NSCC_PYTORCH_MODULE:-pytorch/2.6.0-py3-cu11.8}"
  module list
else
  echo "NSCC module command is not available." >&2
  exit 1
fi

export PYTHONUNBUFFERED=1
INSTALL_CNTP="${INSTALL_CNTP:-0}"
export PYO3_USE_ABI3_FORWARD_COMPATIBILITY="${PYO3_USE_ABI3_FORWARD_COMPATIBILITY:-1}"
export PIP_CACHE_DIR="${PIP_CACHE_DIR:-${HOME}/scratch/pip-cache}"
mkdir -p "${PIP_CACHE_DIR}"

python3 -V
python3 -m pip --version
python3 -m pip install --user --upgrade pip setuptools wheel
COMMON_PACKAGES=(
  accelerate
  func_timeout
  ipdb
  jsonlines
  matplotlib
  openai==0.28.1
  pandas
  "peft>=0.13.2"
  python-dateutil
  pyyaml
  regex
  safetensors
  sentencepiece
  sympy
  tenacity
  tqdm
)

if [[ "${INSTALL_CNTP}" == "1" ]]; then
  python3 -m pip install --user --upgrade \
    "${COMMON_PACKAGES[@]}" \
    "huggingface-hub>=0.23.2,<1.0" \
    "tokenizers>=0.19,<0.20"
  python3 -m pip install --user --upgrade -e ASPS/custom_transformers_packages/gsm8k_strategyqa
else
  python3 -m pip uninstall -y transformers || true
  python3 -m pip install --user --upgrade \
    "${COMMON_PACKAGES[@]}" \
    "transformers>=4.44,<5"
fi

python3 - <<'PY'
import importlib

mods = [
    "torch",
    "transformers",
    "yaml",
    "pandas",
    "tqdm",
    "jsonlines",
    "regex",
    "func_timeout",
    "sympy",
    "matplotlib",
    "openai",
    "accelerate",
    "peft",
    "sentencepiece",
]

for name in mods:
    mod = importlib.import_module(name)
    print(name, "OK", getattr(mod, "__version__", ""))
PY

if [[ "${INSTALL_CNTP}" != "1" ]]; then
  python3 - <<'PY'
from transformers import AutoModelForCausalLM, AutoTokenizer
print("transformers Auto* imports OK")
PY
fi

echo "finished_at: $(date)"
echo "log_file: ${LOG_FILE}"
